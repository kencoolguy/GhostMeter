{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "vite": ["/home/ken/.ghostmeter-frontend-modules/node_modules/vite/dist/node/index.d.ts"],
      "vite/*": ["/home/ken/.ghostmeter-frontend-modules/node_modules/vite/*"],
      "@vitejs/plugin-react": ["/home/ken/.ghostmeter-frontend-modules/node_modules/@vitejs/plugin-react/dist/index.d.ts"],
      "@vitejs/plugin-react/*": ["/home/ken/.ghostmeter-frontend-modules/node_modules/@vitejs/plugin-react/*"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["vite.config.ts"]
}
