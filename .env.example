OPCUA_PORT=4840
OPCUA_ENDPOINT_PATH=/ghostmeter/server/
OPCUA_SERVER_NAME=GhostMeter OPC UA Server
OPCUA_NAMESPACE_URI=http://ghostmeter.local/opcua/

# Frontend
VITE_API_BASE_URL=http://localhost:8000
